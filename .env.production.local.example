# Production environment variables for Firebase Hosting deployment
# Copy this file to .env.production.local and fill in your real values from:
# Firebase Console → Project Settings → Your apps → Web app → Config

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# IMPORTANT: Must be false in production — never connect to local emulators
NEXT_PUBLIC_USE_EMULATORS=false
