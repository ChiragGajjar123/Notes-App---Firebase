rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      // Anyone can read images (allowing shared notes to render images properly)
      allow read: if true;
      // Only the authenticated owner can write/delete files under their folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
