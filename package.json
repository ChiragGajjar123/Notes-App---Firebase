{
  "name": "notes-app-firebase",
  "version": "1.0.0",
  "private": true,
  "main": "functions/index.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "postbuild": "node scripts/copy-public.js",
    "start": "next start",
    "lint": "next lint",
    "predeploy:check": "node scripts/check-env.js",
    "deploy": "npm run predeploy:check && npm run build && firebase deploy",
    "deploy:hosting": "npm run predeploy:check && npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "emulators": "firebase emulators:start --only auth,firestore,storage --project demo-notes-app --import .emulator-data --export-on-exit .emulator-data",
    "emulators:fresh": "firebase emulators:start --only auth,firestore,storage --project demo-notes-app",
    "emulators:ui": "start http://127.0.0.1:4000"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tailwindcss/postcss": "^4.0.0",
    "@tiptap/extension-character-count": "^2.2.4",
    "@tiptap/extension-code-block-lowlight": "^2.2.4",
    "@tiptap/extension-image": "^2.2.4",
    "@tiptap/extension-link": "^2.2.4",
    "@tiptap/extension-placeholder": "^2.2.4",
    "@tiptap/extension-task-item": "^2.2.4",
    "@tiptap/extension-task-list": "^2.2.4",
    "@tiptap/react": "^2.2.4",
    "@tiptap/starter-kit": "^2.2.4",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "firebase": "^11.0.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "framer-motion": "^11.11.0",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "lowlight": "^3.1.0",
    "lucide-react": "^0.454.0",
    "next": "16.2.9",
    "postcss": "^8.4.38",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20.14.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.5.0",
    "eslint-config-next": "16.2.9",
    "typescript": "^5.5.2"
  }
}
